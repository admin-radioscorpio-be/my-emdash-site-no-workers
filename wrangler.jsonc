{           
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "www",
	"main": "./src/worker.ts",
	"compatibility_date": "2026-02-24",
	"compatibility_flags": ["nodejs_compat"],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "my-emdash-site",
			// Run `wrangler d1 create my-emdash-site` and paste the real ID here for deploy
			"database_id": "0dbdb94b-a620-480d-9673-ffa9c4f48158",
		},
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "my-emdash-media","preview_bucket_name": "my-emdash-media",
		},
	],
    "worker_loaders": [
		{
			"binding": "LOADER",
		},
	]
}
